SERVER_PORT=8081
# 5433 — если Postgres в Docker (docker-compose), 5432 — если локальный
DATABASE_URL=postgres://postgres:postgres@localhost:5433/auth?sslmode=disable
REDIS_URL=redis://localhost:6379/0
JWT_SECRET=your-secret-change-in-production
# Access-токен на 24 часа (1440 мин). В prod можно 15.
JWT_ACCESS_TTL_MINUTES=1440
JWT_REFRESH_TTL_DAYS=7
